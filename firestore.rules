rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Restrict profile doc writes to safe, user-owned fields.
    function userWriteIsSafe(userId) {
      return isSelf(userId)
        // Only allow the app-managed profile fields to change.
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'displayName',
          'photoURL',
          'bio',
          'providerId',
          'createdAt',
          'lastLoginAt',
          'following',
          'followers',
          'blockedUsers',
          'mutedPosts',
          'postCount'
        ])
        // Prevent swapping identity / taking over another user doc.
        && (!('uid' in request.resource.data) || request.resource.data.uid == userId)
        && (!('email' in request.resource.data) || request.resource.data.email == resource.data.email);
    }

    // =============================================================================================
    // USERS
    // =============================================================================================
    // Collection name should match VITE_USERS_COLLECTION / USERS_COLLECTION (typically "users").
    match /users/{userId} {
      allow read: if true;
      allow create: if userWriteIsSafe(userId);
      allow update: if userWriteIsSafe(userId);
      allow delete: if false;
    }

    // =============================================================================================
    // POSTS (published)
    // =============================================================================================
    match /posts/{postId} {
      // Public can read only published posts; owner can also read their own (e.g. drafts if added later).
      allow get, list: if (resource.data.status == 'published')
        || (signedIn() && resource.data.uid == request.auth.uid);

      // Create: authenticated user, must write their own uid, only allow published or scheduled (if you ever use single collection).
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status in ['published', 'scheduled'];

      // Updates are split: owner edits content; everyone can only touch counters/arrays used by UI.
      allow update: if signedIn() && (
        // Owner can edit their post (but can't change ownership).
        (resource.data.uid == request.auth.uid
          && request.resource.data.uid == resource.data.uid)
        ||
        // Non-owner can only increment views/likes/reactions and toggle arrays.
        (resource.data.uid != request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'views',
            'likes',
            'likedBy',
            'reactions'
          ]))
      );

      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // =============================================================================================
    // SCHEDULED POSTS
    // =============================================================================================
    // Cloud Function publishes scheduled posts using Admin SDK (bypasses rules).
    // Client can manage ONLY their own scheduled posts.
    // Collection name in your env: VITE_POST_COLLECTION_SCEDULED / POST_COLLECTION_SCEDULED = "postsSceduled"
    match /postsSceduled/{postId} {
      allow get, list: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'scheduled';
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // =============================================================================================
    // COMMENTS
    // =============================================================================================
    match /comments/{commentId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.user.uid == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.text is string;

      // Only the author can edit/delete comment text; anyone signed-in can toggle likes array only.
      allow update: if signedIn() && (
        (resource.data.user.uid == request.auth.uid
          && request.resource.data.user.uid == resource.data.user.uid)
        ||
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['likes'])
      );

      allow delete: if signedIn() && resource.data.user.uid == request.auth.uid;
    }

    // =============================================================================================
    // SERVER-ONLY COLLECTIONS (Admin SDK bypasses rules)
    // =============================================================================================
    // PENDING_USERS = "pendingUsers"
    match /pendingUsers/{docId} {
      allow read, write: if false;
    }

    // OTP_COLLECTION = "passwordResetOTPs"
    match /passwordResetOTPs/{docId} {
      allow read, write: if false;
    }

    // POST_PASSWORD_RESET = "password_resets"
    match /password_resets/{docId} {
      allow read, write: if false;
    }

    // Default deny (avoid "open by accident").
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

