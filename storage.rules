rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    // =============================================================================================
    // Profile photos
    // Path used in app: profile_photos/{uid}/{filename}
    // =============================================================================================
    match /profile_photos/{userId}/{fileName} {
      allow read: if true;
      allow create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    // =============================================================================================
    // Post images
    // Path used in app: posts/{postId}/{filename}
    // =============================================================================================
    match /posts/{postId}/{fileName} {
      allow read: if true;
      // Only signed-in users can upload. (Ownership ties to Firestore post doc would require an additional lookup,
      // which Storage rules can't do reliably without duplicating metadata into the path or custom claims.)
      allow create, update, delete: if signedIn();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

